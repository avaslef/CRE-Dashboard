# CRE Intelligence Dashboard — Environment Variables
# Copy this file to .env.local and fill in your free API keys.
# ─────────────────────────────────────────────────────────────

# 1. FRED API (Federal Reserve Economic Data)
#    Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# 2. U.S. Census Bureau API
#    Free key: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# 3. NewsAPI.org (free developer tier: 100 req/day, 30-day history)
#    Free key: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# 4. BEA (Bureau of Economic Analysis) — optional
#    Free key: https://apps.bea.gov/API/signup/
BEA_API_KEY=your_bea_api_key_here
