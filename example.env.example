# .env.example — Copy this file to .env and fill in your free API keys
# -----------------------------------------------------------------------
# Instructions for each key are in README.md

# 1. FRED API (Federal Reserve Economic Data)
#    Get free key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# 2. U.S. Census Bureau API
#    Get free key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# 3. NewsAPI.org (free developer tier: 100 req/day, 30-day history)
#    Get free key at: https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here
