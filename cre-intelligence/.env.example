# CRE Intelligence Dashboard — Environment Variables
# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local or any file containing real keys to Git.
#
#   cp .env.example .env.local
#
# All keys are FREE. Setup time: ~5 minutes total.


# ── FRED API KEY (Required for all economic charts) ────────────────────────────
# Provider: Federal Reserve Bank of St. Louis
# Sign up:  https://fred.stlouisfed.org/docs/api/api_key.html
#   1. Create a free account at stlouisfed.org
#   2. Go to My Account -> API Keys -> Request API Key
#   3. Key is active immediately
#
FRED_API_KEY=your_fred_api_key_here


# ── U.S. CENSUS BUREAU API KEY (Required for Triangle NC population/income data)
# Provider: U.S. Census Bureau
# Sign up:  https://api.census.gov/data/key_signup.html
#   1. Fill in name and email - key is emailed within minutes
#   2. Free with no rate limit for personal/research use
#
CENSUS_API_KEY=your_census_api_key_here


# ── NEWSAPI KEY (Required for Deal Flow and Brokerage Research news feeds) ────
# Provider: NewsAPI.org
# Sign up:  https://newsapi.org/register
#   1. Register with your email - key shown immediately on the dashboard
#   2. Free developer plan: 100 requests/day, articles from past 30 days
#   NOTE: Without this key the Deal Flow and Brokerage Research pages will
#         display 'No articles found' - the news feeds will NOT function.
#
NEWS_API_KEY=your_newsapi_key_here


# ── BEA API KEY (Optional - for direct BEA GDP data access) ──────────────────
# Provider: Bureau of Economic Analysis
# Sign up:  https://apps.bea.gov/API/signup/
#   Note: GDP data is already available via FRED (FRED_API_KEY) without this.
#         Only needed if you want to query BEA directly.
#
BEA_API_KEY=your_bea_api_key_here
